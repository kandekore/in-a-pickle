# ─────────────────────────────────────────────────────────────
# In a Pickle Breakdown — environment template
# Copy to .env (root), web/.env.local, and server/.env as needed.
# NEVER commit real secrets. All secrets are injected via env vars.
# ─────────────────────────────────────────────────────────────

# ── Shared ──
NODE_ENV=development

# ── Web (Next.js) ── prefix NEXT_PUBLIC_ for browser exposure
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
# Mapbox public access token (pk....) for client-side maps
NEXT_PUBLIC_MAPBOX_TOKEN=

# UK Vehicle Data — number-plate lookup on the request-help flow (server-side
# only; the key must never be exposed to the browser). Set these in web/.env.local
VEHICLE_API_BASE_URL=https://uk1.ukvehicledata.co.uk/api/datapackage
VEHICLE_API_KEY=

# ── Server (Express API) ──
PORT=4000
WEB_ORIGIN=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/in_a_pickle

# Auth — JWT access + refresh (RBAC)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Stripe Connect (marketplace payments / escrow / commission split)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Object storage (S3 or compatible) for document uploads (signed URLs)
S3_ENDPOINT=
S3_REGION=eu-west-2
S3_BUCKET=in-a-pickle-docs
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Notifications
SMS_PROVIDER_API_KEY=
SMTP_URL=

# Mapbox server token (for Directions/ETA on the backend)
MAPBOX_TOKEN=
